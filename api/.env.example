# Copy to .env and fill in. NEVER commit .env.

# HTTP
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgres://fdebijl@localhost:5432/oct_dev

# Secret used to sign JWTs (access tokens). Use a long random string.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-value

# Server-side secret used to derive a deterministic pseudo-salt for unknown
# identifiers during /auth/prelogin (prevents user enumeration). Keep stable.
SERVER_SECRET=change-me-to-another-long-random-value

# Access token lifetime (seconds). 14 days = 1209600.
JWT_EXPIRES_IN=1209600

# Comma-separated list of allowed CORS origins. Use exact origins, not '*'.
CORS_ORIGINS=http://localhost:5173
