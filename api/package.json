{
  "name": "open-cycle-tracker-api",
  "version": "0.0.0-alpha",
  "description": "Self-hosted, end-to-end-encrypted menstrual cycle tracker API",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --target node24 --clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@node-rs/argon2": "2.0.2",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.3",
    "libsodium-wrappers-sumo": "0.8.4",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "^24.13.1",
    "@types/pg": "8.20.0",
    "@types/supertest": "7.2.0",
    "drizzle-kit": "0.31.10",
    "eslint": "10.4.0",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "6.0.2",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f"
}
